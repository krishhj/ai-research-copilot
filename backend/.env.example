# This is an example .env file for the backend of the AI Research Copilot application.

# Application
APP_NAME=AI Research Copilot
APP_VERSION=0.1.0
DEBUG=True

# API
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_PATH=data/database/papers.db
VECTOR_STORE_PATH=data/vector_store

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# Retrieval Chunks
TOP_K=5

# LLM
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.2
MAX_TOKENS=1024